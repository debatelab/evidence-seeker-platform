services:
  backend:
    image: ${BACKEND_IMAGE:-ghcr.io/debatelab/evidence-backend:latest}
    restart: unless-stopped
    env_file: .env.prod
    environment:
      # Example explicit overrides (can also live in env file)
      DATABASE_URL: ${DATABASE_URL}
    volumes:
      - ${UPLOADS_VOLUME_PATH:-./backend/uploads}:${UPLOAD_STORAGE_PATH:-/app/uploads}
      - ./backend/encryption_key:/app/encryption_key:ro
    depends_on:
      db:
        condition: service_healthy
    networks:
      - evidence-seeker-network
    ports:
      - "127.0.0.1:8000:8000"

  frontend:
    image: ${FRONTEND_IMAGE:-ghcr.io/debatelab/evidence-frontend:latest}
    restart: unless-stopped
    environment:
      - VITE_API_URL=${FRONTEND_API_URL:-https://b7233fdd-ac70-4e21-ae82-54a2e6c682e4.ka.bw-cloud-instance.org/api/v1}
    depends_on:
      - backend
    networks:
      - evidence-seeker-network
    expose:
      - "3000"

  db:
    image: pgvector/pgvector:pg16
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${POSTGRES_DB:?unset}
      POSTGRES_USER: ${POSTGRES_USER:?unset}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:?unset}
      PGDATA: /var/lib/postgresql/data/pgdata
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./backup:/backup
    ports:
      - "127.0.0.1:5432:5432"  # Only accessible locally
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U evidence_user -d evidence_seeker"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - evidence-seeker-network

  nginx:
    image: nginx:1.27-alpine
    restart: unless-stopped
    depends_on:
      - backend
      - frontend
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/prod.conf:/etc/nginx/nginx.conf:ro
      - ./ssl:/etc/ssl/certs:ro
      - ${UPLOADS_VOLUME_PATH:-./backend/uploads}:/var/www/uploads:ro

volumes:
  evidence_data:
  vector_data:

# Usage notes:
# 1. Copy to docker-compose.prod.yml and tailor as needed.
# 2. Optionally pin BACKEND_IMAGE / FRONTEND_IMAGE to immutable refs (including @sha256 digest):
#      export BACKEND_IMAGE="ghcr.io/debatelab/evidence-backend@sha256:<digest>"
#      export FRONTEND_IMAGE="ghcr.io/debatelab/evidence-frontend@sha256:<digest>"
#    (defaults fall back to the :latest tags if not provided)
# 3. Provide secrets via an .env.prod file NOT committed to git.
# 4. Start stack: docker compose -f docker-compose.prod.yml up -d
# 5. To update: adjust image env vars (or pull), then docker compose up -d
