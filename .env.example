# Root-level environment variables (shared)
# Populate this (copy to .env) on the server or in CI secrets. Do NOT commit the real .env file.

POSTGRES_DB=evidence_seeker
POSTGRES_USER=evidence_user
POSTGRES_PASSWORD=CHANGE_ME_SECURELY

# Optionally override API base (frontend will treat everything public anyway if exposed)
VITE_API_URL=http://localhost:8000/api/v1
