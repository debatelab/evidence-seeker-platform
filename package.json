{
    "name": "evidence-seeker-platform",
    "version": "1.0.0",
    "description": "Evidence Seeker Platform - A modern full-stack application for AI fact-checking",
    "private": true,
    "workspaces": [
        "frontend"
    ],
    "scripts": {
        "test:db:up": "docker-compose -f docker-compose.dev.yml --profile testing up -d test_db",
        "test:db:down": "docker-compose -f docker-compose.dev.yml --profile testing down -v",
        "backend:test:ci": "cd backend && source .venv/bin/activate && pytest -v --cov=app --cov-report=term-missing",
        "backend:test:local": "export DATABASE_URL=postgresql://evidence_user:evidence_password@localhost:5433/evidence_seeker_test && cd backend && source .venv/bin/activate && pytest -v --cov=app --cov-report=term-missing",
        "test:backend": "npm-run-all test:db:up backend:test:local",
        "dev": "npm-run-all --parallel dev:db dev:backend dev:frontend",
        "dev:db": "docker-compose -f docker-compose.dev.yml up db",
        "dev:backend": "cd backend && source .venv/bin/activate && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
        "dev:frontend": "cd frontend && npm run dev",
        "setup": "npm-run-all setup:db setup:backend setup:frontend",
        "setup:db": "docker-compose -f docker-compose.dev.yml up -d db",
        "setup:backend": "npm run db:reset && cd backend && uv venv && source .venv/bin/activate && uv pip install -e .[dev] && cp .env.dev .env && rm -rf uploads && mkdir -p uploads && alembic upgrade head && python init_db.py",
        "setup:frontend": "cd frontend && npm install",
        "install:all": "npm-run-all setup:backend setup:frontend",
        "db:up": "docker-compose -f docker-compose.dev.yml up -d db",
        "db:down": "docker-compose -f docker-compose.dev.yml down",
        "db:reset": "docker-compose -f docker-compose.dev.yml down -v && docker-compose -f docker-compose.dev.yml up -d db",
        "db:migrate": "cd backend && source .venv/bin/activate && alembic upgrade head",
        "db:init": "cd backend && source .venv/bin/activate && python init_db.py",
        "backend:install": "cd backend && source .venv/bin/activate && uv pip install -e .[dev]",
        "backend:test": "cd backend && source .venv/bin/activate && pytest -v",
        "frontend:install": "cd frontend && npm install",
        "frontend:test": "cd frontend && npm run test",
        "test": "npm-run-all --parallel test:backend frontend:test",
        "lint": "cd backend && source .venv/bin/activate && black --check . && ruff check . && mypy .",
        "ruff-fix": "cd backend && source .venv/bin/activate && ruff check --fix .",
        "format": "cd backend && source .venv/bin/activate && black .",
        "clean": "docker-compose down -v && rm -rf backend/.venv frontend/node_modules frontend/dist",
        "prod:build": "docker-compose build",
        "prod:up": "docker-compose up -d",
        "prod:down": "docker-compose down"
    },
    "devDependencies": {
        "npm-run-all": "^4.1.5"
    },
    "keywords": [
        "ai",
        "fact-checking",
        "evidence",
        "fastapi",
        "react",
        "typescript",
        "postgresql"
    ],
    "author": "Evidence Seeker Team",
    "license": "MIT",
    "engines": {
        "node": ">=24.0.2",
        "npm": ">=11.3.0"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-musl": "4.46.4"
    },
    "overrides": {
        "vite": {
            "rollup": "npm:@rollup/wasm-node"
        }
    }
}